rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isCoupleMember(coupleId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    function validMediaType(data) {
      return (
        data.type == 'image'
        && data.contentType.matches('image/.*')
        && data.size <= 12 * 1024 * 1024
      ) || (
        data.type == 'video'
        && data.contentType.matches('video/.*')
        && data.size <= 50 * 1024 * 1024
      ) || (
        data.type == 'audio'
        && data.contentType.matches('audio/.*')
        && data.size <= 12 * 1024 * 1024
      );
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /pairCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['coupleId', 'ownerUid', 'createdAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow delete: if signedIn() && (
        resource.data.ownerUid == request.auth.uid
        || (
          getAfter(/databases/$(database)/documents/couples/$(resource.data.coupleId)).data.members.size() == 2
          && request.auth.uid in getAfter(/databases/$(database)/documents/couples/$(resource.data.coupleId)).data.members
        )
      );
      allow update: if false;
    }

    match /couples/{coupleId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['members', 'createdBy', 'createdAt'])
        && request.resource.data.members.size() == 1
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && request.resource.data.createdAt == request.time;

      allow get: if signedIn() && (
        request.auth.uid in resource.data.members
        || resource.data.members.size() == 1
      );
      allow list: if false;

      allow update: if signedIn()
        && resource.data.members.size() == 1
        && request.resource.data.members.size() == 2
        && request.resource.data.members.hasAll(resource.data.members)
        && request.auth.uid in request.resource.data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.createdAt == request.time
          && (
            (
              request.resource.data.type == 'text'
              && request.resource.data.keys().hasOnly(['senderId', 'type', 'text', 'createdAt'])
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 1000
            )
            || (
              request.resource.data.type == 'gift'
              && request.resource.data.keys().hasOnly(['senderId', 'type', 'giftEmoji', 'giftName', 'createdAt'])
              && request.resource.data.giftEmoji is string
              && request.resource.data.giftName is string
              && request.resource.data.giftEmoji.size() <= 16
              && request.resource.data.giftName.size() <= 40
            )
            || (
              request.resource.data.type in ['image', 'video', 'audio']
              && request.resource.data.mediaUrl is string
              && request.resource.data.mediaUrl.size() > 0
              && request.resource.data.mediaUrl.size() <= 4096
              && request.resource.data.storagePath is string
              && request.resource.data.storagePath.matches('couples/' + coupleId + '/' + request.auth.uid + '/.*')
              && request.resource.data.contentType is string
              && request.resource.data.fileName is string
              && request.resource.data.fileName.size() > 0
              && request.resource.data.fileName.size() <= 255
              && request.resource.data.size is int
              && request.resource.data.size > 0
              && validMediaType(request.resource.data)
              && request.resource.data.keys().hasOnly([
                'senderId', 'type', 'mediaUrl', 'storagePath', 'contentType',
                'fileName', 'size', 'createdAt'
              ])
            )
            || (
              request.resource.data.type in ['image', 'audio']
              && request.resource.data.mediaData is string
              && request.resource.data.mediaData.size() > 0
              && request.resource.data.mediaData.size() <= 780000
              && request.resource.data.contentType is string
              && request.resource.data.fileName is string
              && request.resource.data.fileName.size() > 0
              && request.resource.data.fileName.size() <= 255
              && request.resource.data.size is int
              && request.resource.data.size > 0
              && request.resource.data.size <= 560 * 1024
              && validMediaType(request.resource.data)
              && request.resource.data.keys().hasOnly([
                'senderId', 'type', 'mediaData', 'contentType',
                'fileName', 'size', 'createdAt'
              ])
            )
          );
        allow update, delete: if false;
      }
    }
  }
}
